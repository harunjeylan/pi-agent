{
  "defaultPolicy": {
    "tools": "ask",
    "bash": "ask",
    "mcp": "ask",
    "skills": "ask",
    "special": "ask",
  },
  "tools": {
    "read": "allow",
    "write": "ask",
  },
  "bash": {
    "git status": "allow",
    "git diff": "allow",
    "git log *": "allow",
    "git *": "ask",
    "rm *": "ask",
    "rmdir *": "ask",
    "chmod *777": "ask",
    "chown *": "ask",
    "git reset *": "ask",
    "git clean *": "ask",
    "git push *--force*": "ask",
    "git push *-f *": "ask",
    "git stash clear": "ask",
    "git reflog expire": "ask",
    "git gc *--prune*": "ask",
    "git filter-branch": "ask",
    "git checkout -- .": "ask",
    "git restore .": "ask",
    "git stash drop": "ask",
    "git branch *-D": "ask",
    "git push * --delete": "ask",
    "git push * :*": "ask",
    "mkfs.*": "ask",
    "dd *of=/dev/*": "ask",
    "kill -9 -1": "ask",
    "killall -9": "ask",
    "pkill -9": "ask",
    "history -c": "ask",
    "sudo rm": "ask",
    "aws s3 rm *--recursive": "ask",
    "aws s3 rb *--force": "ask",
    "aws ec2 terminate-instances": "ask",
    "aws rds delete-db-instance": "ask",
    "aws cloudformation delete-stack": "ask",
    "aws dynamodb delete-table": "ask",
    "aws eks delete-cluster": "ask",
    "aws lambda delete-function": "ask",
    "aws iam delete-role": "ask",
    "aws iam delete-user": "ask",
    "gcloud projects delete": "ask",
    "gcloud compute instances delete": "ask",
    "gcloud sql instances delete": "ask",
    "gcloud container clusters delete": "ask",
    "gcloud storage rm *-r": "ask",
    "gcloud functions delete": "ask",
    "gcloud iam service-accounts delete": "ask",
    "gcloud run services delete": "ask",
    "gcloud run jobs delete": "ask",
    "gcloud services disable": "ask",
    "gcloud iam roles delete": "ask",
    "gcloud iam policies": "ask",
    "firebase projects:delete": "ask",
    "firebase firestore:delete *--all-collections": "ask",
    "firebase database:remove": "ask",
    "firebase hosting:disable": "ask",
    "firebase functions:delete": "ask",
    "vercel remove *--yes": "ask",
    "vercel projects rm": "ask",
    "vercel env rm": "ask",
    "vercel rm": "ask",
    "vercel remove": "ask",
    "vercel domains rm": "ask",
    "netlify sites:delete": "ask",
    "netlify functions:delete": "ask",
    "wrangler delete": "ask",
    "wrangler r2 bucket delete": "ask",
    "wrangler kv:namespace delete": "ask",
    "wrangler d1 delete": "ask",
    "wrangler queues delete": "ask",
    "DELETE FROM *;": "ask",
    "DELETE * FROM": "ask",
    "TRUNCATE TABLE": "ask",
    "DROP TABLE": "ask",
    "DROP DATABASE": "ask",
    "DROP SCHEMA": "ask",
    "DELETE FROM * WHERE *": "ask",
    "*": "deny",
  },
  "mcp": {
    "mcp_status": "allow",
    "mcp_list": "allow",
    "mcp_search": "allow",
    "mcp_describe": "allow",
    "*": "deny",
  },
}
